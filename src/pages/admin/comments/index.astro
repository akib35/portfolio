---
/**
 * Admin - Comments Moderation
 * Approve, reject, or delete comments
 */
export const prerender = false;

import Layout from '../../../layouts/Layout.astro';
import { siteConfig } from '../../../config';
---

<Layout title={`Comments - ${siteConfig.name}`}>
  <div id="loading" class="min-h-screen flex items-center justify-center bg-gray-50 dark:bg-gray-900">
    <div class="w-12 h-12 border-4 border-slate-300 dark:border-slate-700 border-t-slate-800 dark:border-t-slate-100 rounded-full animate-spin"></div>
  </div>

  <div id="comments-page" class="hidden min-h-screen bg-gray-50 dark:bg-gray-900">
    <!-- Top Bar -->
    <div class="bg-white dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700 px-6 py-3">
      <div class="max-w-5xl mx-auto flex items-center justify-between">
        <div class="flex items-center gap-4">
          <a href="/admin/dashboard" class="text-gray-500 hover:text-slate-900 dark:hover:text-white no-underline">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
            </svg>
          </a>
          <h1 class="text-lg font-bold text-gray-900 dark:text-white">Comments</h1>
        </div>
      </div>
    </div>

    <!-- Filter Tabs -->
    <div class="max-w-5xl mx-auto px-6 pt-6">
      <div class="flex gap-2 mb-6">
        <button data-filter="pending" class="filter-tab px-4 py-2 text-sm font-medium rounded-lg bg-slate-200 text-slate-800 dark:bg-slate-700 dark:text-slate-200">
          Pending <span id="count-pending" class="ml-1">(0)</span>
        </button>
        <button data-filter="approved" class="filter-tab px-4 py-2 text-sm font-medium rounded-lg bg-gray-100 text-gray-600 dark:bg-gray-800 dark:text-gray-400">
          Approved <span id="count-approved" class="ml-1">(0)</span>
        </button>
        <button data-filter="all" class="filter-tab px-4 py-2 text-sm font-medium rounded-lg bg-gray-100 text-gray-600 dark:bg-gray-800 dark:text-gray-400">
          All <span id="count-all" class="ml-1">(0)</span>
        </button>
      </div>
    </div>

    <!-- Comments List -->
    <div class="max-w-5xl mx-auto px-6 pb-12">
      <div id="comments-list" class="space-y-4"></div>
      <div id="no-comments" class="hidden text-center py-16 text-gray-400 dark:text-gray-500">
        <svg class="w-12 h-12 mx-auto mb-4 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
        </svg>
        <p>No comments found</p>
      </div>
    </div>

    <!-- Rejection Modal -->
    <div id="rejection-modal" class="hidden fixed inset-0 z-50 items-center justify-center bg-black/50 backdrop-blur-sm">
      <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-2xl w-full max-w-md mx-4 p-6">
        <h3 id="modal-title" class="text-lg font-bold text-gray-900 dark:text-white mb-1">Reject Comment</h3>
        <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">
          By <strong id="modal-author" class="text-gray-700 dark:text-gray-300"></strong>
        </p>
        <div id="modal-content-preview" class="bg-gray-50 dark:bg-gray-700/50 rounded-lg p-3 mb-4 text-sm text-gray-600 dark:text-gray-300 max-h-24 overflow-y-auto border border-gray-200 dark:border-gray-600"></div>
        <div id="modal-email-section">
          <label class="flex items-center gap-2 mb-3 cursor-pointer">
            <input type="checkbox" id="modal-send-email" class="w-4 h-4 rounded border-gray-300 text-slate-800 focus:ring-slate-500" />
            <span class="text-sm text-gray-700 dark:text-gray-300">Send rejection email to author</span>
          </label>
          <div id="modal-no-email-hint" class="hidden text-xs text-gray-400 mb-3 italic">No email address on this comment — email cannot be sent.</div>
          <textarea id="modal-reason" placeholder="Reason for rejection (optional)" rows="3"
            class="hidden w-full px-3 py-2 text-sm bg-gray-50 dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg text-gray-900 dark:text-white placeholder-gray-400 outline-none focus:ring-2 focus:ring-blue-500 resize-none mb-4"></textarea>
        </div>
        <div class="flex justify-end gap-3">
          <button id="modal-cancel" class="px-4 py-2 text-sm text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors">Cancel</button>
          <button id="modal-confirm" class="px-4 py-2 text-sm font-medium bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors">Confirm</button>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script is:inline>
  const API_HEADERS = () => {
    const token = document.cookie.match(/admin_token=([^;]+)/)?.[1] || '';
    return { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' };
  };

  let allComments = [];
  let currentFilter = 'pending';

  async function init() {
    const token = document.cookie.match(/admin_token=([^;]+)/)?.[1];
    if (!token) { window.location.href = '/admin/login'; return; }

    try {
      const res = await fetch('/api/auth/login', { headers: API_HEADERS() });
      const data = await res.json();
      if (!data.success) { window.location.href = '/admin/login'; return; }
    } catch { window.location.href = '/admin/login'; return; }

    document.getElementById('loading').classList.add('hidden');
    document.getElementById('comments-page').classList.remove('hidden');

    await loadComments();
    setupFilters();
  }

  async function loadComments() {
    try {
      const res = await fetch('/api/comments?all=true', { headers: API_HEADERS() });
      const data = await res.json();
      allComments = data.success ? data.comments : [];
      updateCounts();
      renderComments();
    } catch {
      allComments = [];
      renderComments();
    }
  }

  function updateCounts() {
    const pending = allComments.filter(c => !c.is_approved).length;
    const approved = allComments.filter(c => c.is_approved).length;
    document.getElementById('count-pending').textContent = `(${pending})`;
    document.getElementById('count-approved').textContent = `(${approved})`;
    document.getElementById('count-all').textContent = `(${allComments.length})`;
  }

  function renderComments() {
    let filtered = allComments;
    if (currentFilter === 'pending') filtered = allComments.filter(c => !c.is_approved);
    else if (currentFilter === 'approved') filtered = allComments.filter(c => c.is_approved);

    const list = document.getElementById('comments-list');
    const noComments = document.getElementById('no-comments');

    if (filtered.length === 0) {
      list.innerHTML = '';
      noComments.classList.remove('hidden');
      return;
    }

    noComments.classList.add('hidden');
    list.innerHTML = filtered.map(c => {
      const date = new Date(c.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric', hour: '2-digit', minute: '2-digit' });
      const statusBadge = c.is_approved
        ? '<span class="text-xs px-2 py-0.5 rounded-full bg-slate-200 dark:bg-slate-700 text-slate-700 dark:text-slate-200">Approved</span>'
        : '<span class="text-xs px-2 py-0.5 rounded-full bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300">Pending</span>';

      const parentInfo = c.parent_id ? `<span class="text-xs text-gray-400 dark:text-gray-500 ml-2">↳ Reply</span>` : '';

      return `
        <div class="bg-white dark:bg-gray-800 rounded-xl p-5 border border-gray-200 dark:border-gray-700">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-2 flex-wrap">
                <span class="font-medium text-gray-900 dark:text-white text-sm">${escapeHtml(c.author_name)}</span>
                ${c.author_email ? `<span class="text-xs text-gray-400 dark:text-gray-500">${escapeHtml(c.author_email)}</span>` : ''}
                ${statusBadge}
                ${parentInfo}
              </div>
              <p class="text-gray-700 dark:text-gray-300 text-sm mb-2">${escapeHtml(c.content)}</p>
              <div class="flex items-center gap-3 text-xs text-gray-400 dark:text-gray-500">
                <span>${date}</span>
                ${c.post_title ? `<span>on <strong>${escapeHtml(c.post_title)}</strong></span>` : ''}
              </div>
            </div>
            <div class="flex items-center gap-2 shrink-0">
              ${!c.is_approved ? `
                <button onclick="approveComment(${c.id})" class="px-3 py-1.5 text-xs bg-slate-200 dark:bg-slate-700 text-slate-700 dark:text-slate-200 rounded-lg hover:bg-slate-300 dark:hover:bg-slate-600 transition-colors">
                  Approve
                </button>
              ` : `
                <button onclick="rejectComment(${c.id})" class="px-3 py-1.5 text-xs bg-slate-200 dark:bg-slate-700 text-slate-700 dark:text-slate-200 rounded-lg hover:bg-slate-300 dark:hover:bg-slate-600 transition-colors">
                  Unapprove
                </button>
              `}
              <button onclick="deleteComment(${c.id})" class="px-3 py-1.5 text-xs bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-400 rounded-lg hover:bg-red-200 dark:hover:bg-red-900/50 transition-colors">
                Delete
              </button>
            </div>
          </div>
        </div>
      `;
    }).join('');
  }

  function escapeHtml(text) {
    const d = document.createElement('div');
    d.textContent = text || '';
    return d.innerHTML;
  }

  function setupFilters() {
    const activeClass = 'filter-tab px-4 py-2 text-sm font-medium rounded-lg bg-slate-200 text-slate-800 dark:bg-slate-700 dark:text-slate-200';
    const inactiveClass = 'filter-tab px-4 py-2 text-sm font-medium rounded-lg bg-gray-100 text-gray-600 dark:bg-gray-800 dark:text-gray-400';

    function renderFilterTabs() {
      document.querySelectorAll('.filter-tab').forEach((t) => {
        t.className = t.dataset.filter === currentFilter ? activeClass : inactiveClass;
      });
    }

    renderFilterTabs();

    document.querySelectorAll('.filter-tab').forEach(tab => {
      tab.addEventListener('click', () => {
        currentFilter = tab.dataset.filter;
        renderFilterTabs();
        renderComments();
      });
    });
  }

  window.approveComment = async function(id) {
    try {
      const res = await fetch(`/api/comments/${id}`, {
        method: 'PATCH',
        headers: API_HEADERS(),
        body: JSON.stringify({ is_approved: true }),
      });
      const data = await res.json();
      if (data.success) await loadComments();
      else alert(data.error || 'Failed');
    } catch { alert('Error approving comment'); }
  };

  // ── Rejection / Delete modal logic ──────────────────────────────
  let modalAction = null; // { type: 'reject' | 'delete', id: number }

  function openModal(type, id) {
    const comment = allComments.find(c => c.id === id);
    if (!comment) return;

    modalAction = { type, id };
    const modal = document.getElementById('rejection-modal');
    document.getElementById('modal-title').textContent = type === 'delete' ? 'Delete Comment' : 'Reject Comment';
    document.getElementById('modal-author').textContent = comment.author_name || 'Anonymous';
    document.getElementById('modal-content-preview').textContent = comment.content || '';
    document.getElementById('modal-confirm').textContent = type === 'delete' ? 'Delete' : 'Reject';
    document.getElementById('modal-confirm').className = type === 'delete'
      ? 'px-4 py-2 text-sm font-medium bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors'
      : 'px-4 py-2 text-sm font-medium bg-slate-800 text-white dark:bg-slate-100 dark:text-slate-900 rounded-lg hover:bg-slate-700 dark:hover:bg-white transition-colors';

    // Reset form state
    const checkbox = document.getElementById('modal-send-email');
    const reason = document.getElementById('modal-reason');
    const noEmailHint = document.getElementById('modal-no-email-hint');
    checkbox.checked = false;
    reason.classList.add('hidden');
    reason.value = '';

    if (comment.author_email) {
      checkbox.disabled = false;
      checkbox.parentElement.classList.remove('opacity-50');
      noEmailHint.classList.add('hidden');
    } else {
      checkbox.disabled = true;
      checkbox.parentElement.classList.add('opacity-50');
      noEmailHint.classList.remove('hidden');
    }

    modal.classList.remove('hidden');
    modal.classList.add('flex');
  }

  function closeModal() {
    const m = document.getElementById('rejection-modal');
    if (m) { m.classList.add('hidden'); m.classList.remove('flex'); }
    modalAction = null;
  }

  document.getElementById('modal-cancel').addEventListener('click', closeModal);
  document.getElementById('rejection-modal').addEventListener('click', function(e) {
    if (e.target === this) closeModal();
  });

  document.getElementById('modal-send-email').addEventListener('change', function() {
    const reason = document.getElementById('modal-reason');
    if (this.checked) reason.classList.remove('hidden');
    else reason.classList.add('hidden');
  });

  document.getElementById('modal-confirm').addEventListener('click', async function() {
    if (!modalAction) return;
    const btn = this;
    btn.disabled = true;
    btn.textContent = 'Processing...';

    const sendEmail = document.getElementById('modal-send-email').checked;
    const reason = document.getElementById('modal-reason').value.trim();

    try {
      if (modalAction.type === 'reject') {
        const res = await fetch(`/api/comments/${modalAction.id}`, {
          method: 'PATCH',
          headers: API_HEADERS(),
          body: JSON.stringify({ is_approved: false, send_email: sendEmail, rejection_reason: reason || undefined }),
        });
        const data = await res.json();
        if (!data.success) { alert(data.error || 'Failed'); return; }
        if (sendEmail && data.email_sent) {
          showToast('Comment rejected & email sent');
        } else if (sendEmail && !data.email_sent) {
          showToast('Comment rejected — email failed to send', true);
        } else {
          showToast('Comment rejected');
        }
      } else {
        const res = await fetch(`/api/comments/${modalAction.id}`, {
          method: 'DELETE',
          headers: { ...API_HEADERS() },
          body: JSON.stringify({ send_email: sendEmail, rejection_reason: reason || undefined }),
        });
        const data = await res.json();
        if (!data.success) { alert(data.error || 'Failed'); return; }
        if (sendEmail && data.email_sent) {
          showToast('Comment deleted & email sent');
        } else if (sendEmail && !data.email_sent) {
          showToast('Comment deleted — email failed to send', true);
        } else {
          showToast('Comment deleted');
        }
      }
      closeModal();
      await loadComments();
    } catch {
      alert('Error processing action');
    } finally {
      btn.disabled = false;
    }
  });

  function showToast(msg, isError) {
    const toast = document.createElement('div');
    toast.className = 'fixed bottom-6 right-6 z-50 px-5 py-3 rounded-xl text-sm font-medium shadow-lg transition-all ' +
      (isError ? 'bg-red-600 text-white' : 'bg-green-600 text-white');
    toast.textContent = msg;
    document.body.appendChild(toast);
    setTimeout(() => { toast.style.opacity = '0'; setTimeout(() => toast.remove(), 300); }, 3000);
  }

  window.rejectComment = function(id) { openModal('reject', id); };
  window.deleteComment = function(id) { openModal('delete', id); };

  init();
</script>
