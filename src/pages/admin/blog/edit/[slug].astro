---
/**
 * Admin - Edit Blog Post
 * Rich text editor powered by TipTap (pre-loaded with existing data)
 */
export const prerender = false;

import Layout from '../../../../layouts/Layout.astro';
import { siteConfig } from '../../../../config';

const { slug } = Astro.params;
---

<Layout title={`Edit Post - ${siteConfig.name}`}>
  <div id="loading" class="min-h-screen flex items-center justify-center bg-gray-50 dark:bg-gray-900">
    <div class="w-12 h-12 border-4 border-blue-200 border-t-blue-600 rounded-full animate-spin"></div>
  </div>

  <div id="editor-page" class="hidden min-h-screen bg-gray-50 dark:bg-gray-900">
    <!-- Top Bar -->
    <div class="bg-white dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700 px-6 py-3 sticky top-0 z-40">
      <div class="max-w-6xl mx-auto flex items-center justify-between">
        <div class="flex items-center gap-4">
          <a href="/admin/blog" class="text-gray-500 hover:text-blue-600 no-underline">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
            </svg>
          </a>
          <h1 class="text-lg font-bold text-gray-900 dark:text-white">Edit Post</h1>
          <span id="post-status-badge" class="text-xs px-2 py-1 rounded-full"></span>
        </div>
        <div class="flex items-center gap-2">
          <button id="save-draft" class="btn btn-secondary text-sm py-2 px-4">Save Draft</button>
          <button id="publish-btn" class="btn btn-primary text-sm py-2 px-4">Publish</button>
          <button id="unpublish-btn" class="hidden btn btn-secondary text-sm py-2 px-4 text-orange-600">Unpublish</button>
        </div>
      </div>
    </div>

    <!-- Editor Content -->
    <div class="max-w-6xl mx-auto px-6 py-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Main Editor Column -->
        <div class="lg:col-span-2 space-y-6">
          <!-- Title -->
          <div>
            <input type="text" id="post-title" placeholder="Post title..."
              class="w-full text-3xl font-bold bg-transparent border-none outline-none text-gray-900 dark:text-white placeholder-gray-300 dark:placeholder-gray-600" />
          </div>

          <!-- Slug -->
          <div class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400">
            <span>/blog/</span>
            <input type="text" id="post-slug" placeholder="auto-generated-slug"
              class="flex-1 bg-transparent border-b border-dashed border-gray-300 dark:border-gray-600 outline-none text-gray-700 dark:text-gray-300 py-1" />
          </div>

          <!-- Excerpt -->
          <div>
            <textarea id="post-excerpt" placeholder="Write a brief excerpt for this post..."
              rows="2"
              class="w-full px-4 py-3 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl text-gray-900 dark:text-white placeholder-gray-400 resize-none outline-none focus:ring-2 focus:ring-blue-500"></textarea>
          </div>

          <!-- TipTap Toolbar -->
          <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden">
            <div id="toolbar" class="flex flex-wrap gap-1 p-2 border-b border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800/50">
              <button data-action="bold" title="Bold" class="toolbar-btn p-2 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-300">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 4h8a4 4 0 014 4 4 4 0 01-4 4H6z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 12h9a4 4 0 014 4 4 4 0 01-4 4H6z"/></svg>
              </button>
              <button data-action="italic" title="Italic" class="toolbar-btn p-2 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-300">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 4h4m-2 0l-4 16m0 0h4"/></svg>
              </button>
              <button data-action="strike" title="Strikethrough" class="toolbar-btn p-2 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-300">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 4H9l-.3 1.5M4 12h16M8 20h7l.3-1.5"/></svg>
              </button>
              <div class="w-px h-6 bg-gray-200 dark:bg-gray-700 self-center mx-1"></div>
              <button data-action="heading1" title="Heading 1" class="toolbar-btn p-2 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-300 text-sm font-bold">H1</button>
              <button data-action="heading2" title="Heading 2" class="toolbar-btn p-2 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-300 text-sm font-bold">H2</button>
              <button data-action="heading3" title="Heading 3" class="toolbar-btn p-2 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-300 text-sm font-bold">H3</button>
              <div class="w-px h-6 bg-gray-200 dark:bg-gray-700 self-center mx-1"></div>
              <button data-action="bulletList" title="Bullet List" class="toolbar-btn p-2 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-300">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01"/></svg>
              </button>
              <button data-action="orderedList" title="Ordered List" class="toolbar-btn p-2 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-300">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 8h10M7 12h10M7 16h10M3 8V6l2-1M3 12v-1l1-1M3 16v2l2 1"/></svg>
              </button>
              <button data-action="blockquote" title="Blockquote" class="toolbar-btn p-2 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-300">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151C7.563 6.068 6 8.789 6 11h4v10H0z"/></svg>
              </button>
              <button data-action="codeBlock" title="Code Block" class="toolbar-btn p-2 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-300">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>
              </button>
              <div class="w-px h-6 bg-gray-200 dark:bg-gray-700 self-center mx-1"></div>
              <button data-action="link" title="Add Link" class="toolbar-btn p-2 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-300">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
              </button>
              <button data-action="image" title="Add Image" class="toolbar-btn p-2 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-300">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
              </button>
              <div class="w-px h-6 bg-gray-200 dark:bg-gray-700 self-center mx-1"></div>
              <button data-action="undo" title="Undo" class="toolbar-btn p-2 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-300">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6"/></svg>
              </button>
              <button data-action="redo" title="Redo" class="toolbar-btn p-2 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-300">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 10H11a8 8 0 00-8 8v2m18-10l-6 6m6-6l-6-6"/></svg>
              </button>
            </div>
            <!-- TipTap Editor Container -->
            <div id="editor" class="prose prose-lg max-w-none dark:prose-invert p-6 min-h-100 focus:outline-none"></div>
          </div>
        </div>

        <!-- Sidebar -->
        <div class="space-y-6">
          <!-- Tags -->
          <div class="bg-white dark:bg-gray-800 rounded-xl p-5 border border-gray-200 dark:border-gray-700">
            <h3 class="text-sm font-semibold text-gray-900 dark:text-white mb-3">Tags</h3>
            <div id="tags-container" class="flex flex-wrap gap-2 mb-3"></div>
            <div class="flex gap-2">
              <input type="text" id="tag-input" placeholder="Add tag..."
                class="flex-1 px-3 py-2 text-sm bg-gray-50 dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg outline-none focus:ring-2 focus:ring-blue-500 text-gray-900 dark:text-white" />
              <button id="add-tag-btn" class="px-3 py-2 text-sm bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-400 rounded-lg hover:bg-blue-200 dark:hover:bg-blue-900/50 transition-colors">Add</button>
            </div>
          </div>

          <!-- Settings -->
          <div class="bg-white dark:bg-gray-800 rounded-xl p-5 border border-gray-200 dark:border-gray-700">
            <h3 class="text-sm font-semibold text-gray-900 dark:text-white mb-3">Post Settings</h3>
            <div class="space-y-4">
              <!-- Cover Image URL -->
              <div>
                <label class="block text-xs font-medium text-gray-500 dark:text-gray-400 mb-1">Cover Image URL</label>
                <input type="text" id="cover-image" placeholder="https://..."
                  class="w-full px-3 py-2 text-sm bg-gray-50 dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg outline-none focus:ring-2 focus:ring-blue-500 text-gray-900 dark:text-white" />
              </div>

              <!-- Comments -->
              <div class="flex items-center justify-between">
                <label class="text-sm text-gray-700 dark:text-gray-300">Allow Comments</label>
                <label class="relative inline-flex items-center cursor-pointer">
                  <input type="checkbox" id="allow-comments" checked class="sr-only peer" />
                  <div class="w-9 h-5 bg-gray-200 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-blue-300 dark:peer-focus:ring-blue-800 rounded-full peer dark:bg-gray-600 peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-0.5 after:left-0.5 after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all dark:after:border-gray-500 peer-checked:bg-blue-600"></div>
                </label>
              </div>

              <!-- Comments Close After -->
              <div>
                <label class="block text-xs font-medium text-gray-500 dark:text-gray-400 mb-1">Close Comments After (days)</label>
                <input type="number" id="comments-close-days" placeholder="Leave empty for never" min="1"
                  class="w-full px-3 py-2 text-sm bg-gray-50 dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg outline-none focus:ring-2 focus:ring-blue-500 text-gray-900 dark:text-white" />
              </div>
            </div>
          </div>

          <!-- Post Info -->
          <div id="post-info" class="bg-white dark:bg-gray-800 rounded-xl p-5 border border-gray-200 dark:border-gray-700">
            <h3 class="text-sm font-semibold text-gray-900 dark:text-white mb-3">Post Info</h3>
            <div class="space-y-2 text-sm text-gray-500 dark:text-gray-400">
              <div id="info-created"></div>
              <div id="info-updated"></div>
              <div id="info-published"></div>
            </div>
          </div>

          <!-- Status Indicator -->
          <div id="save-status" class="text-center text-sm text-gray-400 dark:text-gray-500"></div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style is:global>
  .ProseMirror {
    outline: none;
    min-height: 400px;
  }
  .ProseMirror p.is-editor-empty:first-child::before {
    content: attr(data-placeholder);
    float: left;
    color: #9ca3af;
    pointer-events: none;
    height: 0;
  }
  .ProseMirror h1 { font-size: 2rem; font-weight: 700; margin: 1rem 0; }
  .ProseMirror h2 { font-size: 1.5rem; font-weight: 600; margin: 0.75rem 0; }
  .ProseMirror h3 { font-size: 1.25rem; font-weight: 600; margin: 0.5rem 0; }
  .ProseMirror ul, .ProseMirror ol { padding-left: 1.5rem; margin: 0.5rem 0; }
  .ProseMirror li { margin: 0.25rem 0; }
  .ProseMirror blockquote { border-left: 3px solid #3B82F6; padding-left: 1rem; margin: 0.5rem 0; font-style: italic; color: #6B7280; }
  .ProseMirror pre { background: #1f2937; color: #f3f4f6; padding: 1rem; border-radius: 0.5rem; overflow-x: auto; margin: 0.5rem 0; }
  .ProseMirror code { background: #f3f4f6; padding: 0.15rem 0.4rem; border-radius: 0.25rem; font-size: 0.875rem; }
  .dark .ProseMirror code { background: #374151; }
  .ProseMirror pre code { background: none; padding: 0; }
  .ProseMirror img { max-width: 100%; border-radius: 0.5rem; margin: 0.5rem 0; }
  .ProseMirror a { color: #3B82F6; text-decoration: underline; }
  .toolbar-btn.is-active { background: #DBEAFE; color: #2563EB; }
  .dark .toolbar-btn.is-active { background: rgb(30 58 138 / 0.3); color: #60A5FA; }
</style>

<script is:inline define:vars={{ slug }}>
  window.__postSlug = slug;
</script>

<script>
  import { Editor } from '@tiptap/core';
  import StarterKit from '@tiptap/starter-kit';
  import Image from '@tiptap/extension-image';
  import Link from '@tiptap/extension-link';
  import Placeholder from '@tiptap/extension-placeholder';

  declare global {
    interface Window { __postSlug: string; removeTag: (index: number) => void; }
  }

  const postSlug = window.__postSlug;

  const API_HEADERS = () => {
    const token = document.cookie.match(/admin_token=([^;]+)/)?.[1] || '';
    return { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' };
  };

  // Auth check
  const token = document.cookie.match(/admin_token=([^;]+)/)?.[1];
  if (!token) { window.location.href = '/admin/login'; }

  try {
    const res = await fetch('/api/auth/login', { headers: API_HEADERS() });
    const data = await res.json();
    if (!data.success) { window.location.href = '/admin/login'; }
  } catch { window.location.href = '/admin/login'; }

  // Load post data
  let postData = null;
  try {
    const res = await fetch(`/api/blog/${postSlug}`, { headers: API_HEADERS() });
    const data = await res.json();
    if (!data.success || !data.post) {
      alert('Post not found');
      window.location.href = '/admin/blog';
    }
    postData = data.post;
  } catch {
    alert('Failed to load post');
    window.location.href = '/admin/blog';
  }

  document.getElementById('loading')?.classList.add('hidden');
  document.getElementById('editor-page')?.classList.remove('hidden');

  // Populate fields
  (document.getElementById('post-title') as HTMLInputElement).value = postData.title;
  (document.getElementById('post-slug') as HTMLInputElement).value = postData.slug;
  (document.getElementById('post-excerpt') as HTMLTextAreaElement).value = postData.excerpt || '';
  (document.getElementById('cover-image') as HTMLInputElement).value = postData.cover_image || '';
  (document.getElementById('allow-comments') as HTMLInputElement).checked = postData.allow_comments !== 0;

  // Status badge
  const badge = document.getElementById('post-status-badge');
  if (postData.status === 'published') {
    badge!.textContent = 'Published';
    badge!.className = 'text-xs px-2 py-1 rounded-full bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400';
    document.getElementById('unpublish-btn')?.classList.remove('hidden');
    document.getElementById('publish-btn')!.textContent = 'Update';
  } else {
    badge!.textContent = 'Draft';
    badge!.className = 'text-xs px-2 py-1 rounded-full bg-yellow-100 dark:bg-yellow-900/30 text-yellow-700 dark:text-yellow-400';
  }

  // Post info
  const fmt = (d: string | null) => d ? new Date(d).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) : 'N/A';
  document.getElementById('info-created')!.textContent = 'Created: ' + fmt(postData.created_at);
  document.getElementById('info-updated')!.textContent = 'Updated: ' + fmt(postData.updated_at);
  if (postData.published_at) {
    document.getElementById('info-published')!.textContent = 'Published: ' + fmt(postData.published_at);
  }

  // Initialize TipTap with existing content
  const editor = new Editor({
    element: document.getElementById('editor'),
    extensions: [
      StarterKit,
      Image.configure({ inline: false, allowBase64: true }),
      Link.configure({ openOnClick: false }),
      Placeholder.configure({ placeholder: 'Start writing your blog post...' }),
    ],
    content: postData.content_html || '',
    editorProps: {
      attributes: {
        class: 'prose prose-lg max-w-none dark:prose-invert focus:outline-none min-h-100',
      },
    },
    onUpdate: () => updateToolbarState(),
  });

  // Tags
  let tags: string[] = (postData.tags || []).map((t: any) => typeof t === 'string' ? t : t.name);
  const tagsContainer = document.getElementById('tags-container')!;
  const tagInput = document.getElementById('tag-input') as HTMLInputElement;

  function escHtml(s: string) { return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

  function renderTags() {
    tagsContainer.innerHTML = tags.map((tag: string, i: number) => `
      <span class="inline-flex items-center gap-1 px-3 py-1 bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-400 text-sm rounded-full">
        ${escHtml(tag)}
        <button onclick="window.removeTag(${i})" class="hover:text-red-500 ml-0.5">&times;</button>
      </span>
    `).join('');
  }
  renderTags();

  window.removeTag = (index: number) => { tags.splice(index, 1); renderTags(); };

  document.getElementById('add-tag-btn')?.addEventListener('click', () => {
    const val = tagInput.value.trim();
    if (val && !tags.includes(val)) { tags.push(val); renderTags(); tagInput.value = ''; }
  });

  tagInput?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      e.preventDefault();
      document.getElementById('add-tag-btn')?.click();
    }
  });

  // Toolbar
  function updateToolbarState() {
    document.querySelectorAll<HTMLElement>('.toolbar-btn[data-action]').forEach(btn => {
      const action = btn.dataset.action;
      let isActive = false;
      switch (action) {
        case 'bold': isActive = editor.isActive('bold'); break;
        case 'italic': isActive = editor.isActive('italic'); break;
        case 'strike': isActive = editor.isActive('strike'); break;
        case 'heading1': isActive = editor.isActive('heading', { level: 1 }); break;
        case 'heading2': isActive = editor.isActive('heading', { level: 2 }); break;
        case 'heading3': isActive = editor.isActive('heading', { level: 3 }); break;
        case 'bulletList': isActive = editor.isActive('bulletList'); break;
        case 'orderedList': isActive = editor.isActive('orderedList'); break;
        case 'blockquote': isActive = editor.isActive('blockquote'); break;
        case 'codeBlock': isActive = editor.isActive('codeBlock'); break;
      }
      btn.classList.toggle('is-active', isActive);
    });
  }

  document.querySelectorAll<HTMLElement>('.toolbar-btn[data-action]').forEach(btn => {
    btn.addEventListener('click', () => {
      const action = btn.dataset.action;
      switch (action) {
        case 'bold': editor.chain().focus().toggleBold().run(); break;
        case 'italic': editor.chain().focus().toggleItalic().run(); break;
        case 'strike': editor.chain().focus().toggleStrike().run(); break;
        case 'heading1': editor.chain().focus().toggleHeading({ level: 1 }).run(); break;
        case 'heading2': editor.chain().focus().toggleHeading({ level: 2 }).run(); break;
        case 'heading3': editor.chain().focus().toggleHeading({ level: 3 }).run(); break;
        case 'bulletList': editor.chain().focus().toggleBulletList().run(); break;
        case 'orderedList': editor.chain().focus().toggleOrderedList().run(); break;
        case 'blockquote': editor.chain().focus().toggleBlockquote().run(); break;
        case 'codeBlock': editor.chain().focus().toggleCodeBlock().run(); break;
        case 'link': {
          const url = prompt('Enter URL:');
          if (url) editor.chain().focus().setLink({ href: url }).run();
          break;
        }
        case 'image': {
          const url = prompt('Enter image URL:');
          if (url) editor.chain().focus().setImage({ src: url }).run();
          break;
        }
        case 'undo': editor.chain().focus().undo().run(); break;
        case 'redo': editor.chain().focus().redo().run(); break;
      }
      updateToolbarState();
    });
  });

  // Save
  async function savePost(status: string) {
    const title = (document.getElementById('post-title') as HTMLInputElement).value.trim();
    if (!title) { alert('Title is required'); return; }

    const content = editor.getText();
    const contentHtml = editor.getHTML();
    if (!content.trim()) { alert('Content is required'); return; }

    const statusEl = document.getElementById('save-status')!;
    statusEl.textContent = 'Saving...';

    try {
      const res = await fetch(`/api/blog/${postSlug}`, {
        method: 'PUT',
        headers: API_HEADERS(),
        body: JSON.stringify({
          title,
          slug: (document.getElementById('post-slug') as HTMLInputElement).value.trim() || undefined,
          excerpt: (document.getElementById('post-excerpt') as HTMLTextAreaElement).value.trim() || undefined,
          content,
          content_html: contentHtml,
          cover_image: (document.getElementById('cover-image') as HTMLInputElement).value.trim() || undefined,
          status,
          tags: tags.length > 0 ? tags : [],
          allow_comments: (document.getElementById('allow-comments') as HTMLInputElement).checked,
          comments_close_days: (document.getElementById('comments-close-days') as HTMLInputElement).value ? Number((document.getElementById('comments-close-days') as HTMLInputElement).value) : undefined,
        }),
      });

      const data = await res.json();
      if (data.success) {
        statusEl.textContent = 'Saved!';
        const newSlug = (document.getElementById('post-slug') as HTMLInputElement).value.trim();
        if (newSlug && newSlug !== postSlug) {
          setTimeout(() => { window.location.href = `/admin/blog/edit/${newSlug}`; }, 500);
        } else {
          setTimeout(() => { statusEl.textContent = ''; }, 2000);
        }
      } else {
        statusEl.textContent = '';
        alert(data.error || 'Failed to save');
      }
    } catch (err) {
      statusEl.textContent = '';
      alert('Error saving post');
    }
  }

  document.getElementById('save-draft')?.addEventListener('click', () => savePost('draft'));
  document.getElementById('publish-btn')?.addEventListener('click', () => savePost('published'));
  document.getElementById('unpublish-btn')?.addEventListener('click', () => savePost('draft'));
</script>
