---
/**
 * Admin Blog Posts Management
 * Lists all blog posts with actions
 */
export const prerender = false;

import Layout from '../../../layouts/Layout.astro';
import { siteConfig } from '../../../config';
---

<Layout title={`Manage Posts - ${siteConfig.name}`}>
  <div id="loading" class="min-h-screen flex items-center justify-center bg-gray-50 dark:bg-gray-900">
    <div class="w-12 h-12 border-4 border-blue-200 border-t-blue-600 rounded-full animate-spin"></div>
  </div>

  <div id="content" class="hidden min-h-screen bg-gray-50 dark:bg-gray-900">
    <!-- Top Bar -->
    <div class="bg-white dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700 px-6 py-4">
      <div class="max-w-7xl mx-auto flex items-center justify-between">
        <div class="flex items-center gap-4">
          <a href="/admin/dashboard" class="text-gray-500 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 no-underline">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
            </svg>
          </a>
          <h1 class="text-xl font-bold text-gray-900 dark:text-white">Manage Blog Posts</h1>
        </div>
        <a href="/admin/blog/new" class="btn btn-primary text-sm py-2.5">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
          </svg>
          New Post
        </a>
      </div>
    </div>

    <!-- Filter Tabs -->
    <div class="max-w-7xl mx-auto px-6 pt-6">
      <div class="flex gap-2 mb-6">
        <button data-filter="all" class="filter-btn active px-4 py-2 text-sm font-medium rounded-lg bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-400">All</button>
        <button data-filter="published" class="filter-btn px-4 py-2 text-sm font-medium rounded-lg text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800">Published</button>
        <button data-filter="draft" class="filter-btn px-4 py-2 text-sm font-medium rounded-lg text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800">Drafts</button>
      </div>
    </div>

    <!-- Posts List -->
    <div class="max-w-7xl mx-auto px-6 pb-8">
      <div id="posts-list" class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 divide-y divide-gray-100 dark:divide-gray-700">
        <div class="px-6 py-8 text-center text-gray-500">Loading...</div>
      </div>
    </div>
  </div>
</Layout>

<script is:inline>
  const API_HEADERS = () => {
    const token = document.cookie.match(/admin_token=([^;]+)/)?.[1] || '';
    return { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' };
  };

  let allPosts = [];
  let currentFilter = 'all';

  async function init() {
    const token = document.cookie.match(/admin_token=([^;]+)/)?.[1];
    if (!token) { window.location.href = '/admin/login'; return; }

    try {
      const res = await fetch('/api/auth/login', { headers: API_HEADERS() });
      const data = await res.json();
      if (!data.success) { window.location.href = '/admin/login'; return; }
    } catch { window.location.href = '/admin/login'; return; }

    document.getElementById('loading')?.classList.add('hidden');
    document.getElementById('content')?.classList.remove('hidden');

    await loadPosts();

    // Filter buttons
    document.querySelectorAll('.filter-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.filter-btn').forEach(b => {
          b.classList.remove('active', 'bg-blue-100', 'dark:bg-blue-900/30', 'text-blue-700', 'dark:text-blue-400');
          b.classList.add('text-gray-600', 'dark:text-gray-400');
        });
        btn.classList.add('active', 'bg-blue-100', 'dark:bg-blue-900/30', 'text-blue-700', 'dark:text-blue-400');
        btn.classList.remove('text-gray-600', 'dark:text-gray-400');
        currentFilter = btn.dataset.filter;
        renderPosts();
      });
    });
  }

  async function loadPosts() {
    try {
      const res = await fetch('/api/blog?limit=100', { headers: API_HEADERS() });
      const data = await res.json();
      if (data.success) {
        allPosts = data.posts;
        renderPosts();
      }
    } catch (err) {
      document.getElementById('posts-list').innerHTML = '<div class="px-6 py-8 text-center text-red-500">Failed to load posts</div>';
    }
  }

  function escHtml(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;'); }

  function renderPosts() {
    const filtered = currentFilter === 'all' ? allPosts : allPosts.filter(p => p.status === currentFilter);
    const container = document.getElementById('posts-list');

    if (filtered.length === 0) {
      container.innerHTML = '<div class="px-6 py-8 text-center text-gray-500 dark:text-gray-400">No posts found</div>';
      return;
    }

    container.innerHTML = filtered.map(post => `
      <div class="px-6 py-4 flex items-center justify-between hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors">
        <div class="flex-1 min-w-0 mr-4">
          <div class="flex items-center gap-2 mb-1">
            <h3 class="font-semibold text-gray-900 dark:text-white truncate">${escHtml(post.title)}</h3>
            <span class="shrink-0 px-2 py-0.5 text-xs font-medium rounded-full ${
              post.status === 'published' ? 'bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400' :
              post.status === 'draft' ? 'bg-yellow-100 text-yellow-700 dark:bg-yellow-900/30 dark:text-yellow-400' :
              'bg-gray-100 text-gray-700 dark:bg-gray-700 dark:text-gray-400'
            }">${escHtml(post.status)}</span>
          </div>
          <p class="text-sm text-gray-500 dark:text-gray-400">
            ${escHtml(post.excerpt || 'No excerpt')}
          </p>
          <div class="flex items-center gap-3 mt-1 text-xs text-gray-400 dark:text-gray-500">
            <span>${post.published_at ? new Date(post.published_at).toLocaleDateString() : 'Not published'}</span>
            ${post.tags?.length ? '<span>·</span><span>' + post.tags.map(t => escHtml(t.name)).join(', ') + '</span>' : ''}
          </div>
        </div>
        <div class="flex items-center gap-2 shrink-0">
          ${post.status === 'published' ? '<a href="/blog/' + encodeURIComponent(post.slug) + '" target="_blank" class="p-2 text-gray-400 hover:text-blue-600 transition-colors no-underline" title="View"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg></a>' : ''}
          <a href="/admin/blog/edit/${encodeURIComponent(post.slug)}" class="p-2 text-gray-400 hover:text-blue-600 transition-colors no-underline" title="Edit">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
            </svg>
          </a>
          <button onclick="deletePost('${escHtml(post.slug)}')" class="p-2 text-gray-400 hover:text-red-600 transition-colors" title="Delete">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
            </svg>
          </button>
        </div>
      </div>
    `).join('');
  }

  window.deletePost = async function(slug) {
    if (!confirm('Are you sure you want to delete this post?')) return;

    try {
      const res = await fetch('/api/blog/' + slug, { method: 'DELETE', headers: API_HEADERS() });
      const data = await res.json();
      if (data.success) {
        allPosts = allPosts.filter(p => p.slug !== slug);
        renderPosts();
      } else {
        alert(data.error || 'Failed to delete');
      }
    } catch {
      alert('Error deleting post');
    }
  };

  init();
</script>
