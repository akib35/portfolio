---
import Layout from '../layouts/Layout.astro';
import { siteConfig } from '../config';
---

<Layout title={`Page Not Found - ${siteConfig.name}`}>
  <section class="min-h-[70vh] flex items-center py-16">
    <div class="container">
      <div class="max-w-lg mx-auto text-center">
        <div class="card p-8 sm:p-10">
          <p class="mono text-xs uppercase tracking-[0.18em] text-slate-500 dark:text-slate-400 mb-2">Not Found</p>
          <h1 class="text-5xl sm:text-6xl mb-2">404</h1>
          <h2 class="text-2xl mb-3">Page Not Found</h2>
          <p class="text-slate-600 dark:text-slate-300 mb-8">
            The page may have moved or was never published.
          </p>

          <div class="flex flex-col sm:flex-row justify-center gap-3">
            <a href="/" class="btn btn-primary">
              Go Home
            </a>
            <a href="/blog" class="btn border border-slate-300 dark:border-slate-700 text-slate-700 dark:text-slate-200">
              Browse Blog
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
