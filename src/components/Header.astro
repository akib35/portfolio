---
import Navigation from './Navigation.astro';
import ThemeToggle from './ThemeToggle.astro';
import { siteConfig } from '../config';
---

<header class="sticky top-0 z-50 border-b border-slate-200/80 dark:border-slate-800/80 bg-white/85 dark:bg-slate-950/85 backdrop-blur-sm">
  <div class="container py-3">
    <div class="flex justify-between items-center">
      <a href="/" class="group no-underline" aria-label={siteConfig.name}>
        <span class="text-sm font-semibold tracking-[0.18em] uppercase text-slate-900 dark:text-slate-100">
          {siteConfig.site.title}
        </span>
      </a>

      <div class="flex items-center gap-2 sm:gap-4">
        <Navigation />
        <div class="flex items-center gap-2 border-l border-slate-200 dark:border-slate-700 pl-2 sm:pl-3">
          <ThemeToggle />
        </div>
      </div>
    </div>
  </div>
</header>
