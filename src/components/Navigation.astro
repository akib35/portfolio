---
const navItems: Array<{ href: string; label: string }> = [
  { href: '/', label: 'Home' },
  { href: '/blog', label: 'Archive' },
  { href: '/admin/login', label: 'Admin' },
];

const currentPath = Astro.url.pathname;
---

<nav>
  <ul class="flex items-center gap-5">
    {navItems.map(({ href, label }) => (
      <li>
        <a 
          href={href} 
          class:list={[
            "text-sm font-medium tracking-wide text-slate-600 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white transition-colors no-underline",
            { "text-slate-950 dark:text-white": currentPath === href }
          ]}
        >
          {label}
        </a>
      </li>
    ))}
  </ul>
</nav>
