---
import { siteConfig } from "../config";
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-slate-200 dark:border-slate-800 bg-white/70 dark:bg-slate-950/70">
  <div class="container py-8">
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <p class="text-sm text-slate-600 dark:text-slate-400">
        © {currentYear} {siteConfig.name}. Writing in public.
      </p>
      <div class="flex items-center gap-4 text-sm">
        <a href={siteConfig.social.github.link} class="text-slate-600 hover:text-slate-900 dark:text-slate-300 dark:hover:text-white no-underline" target="_blank" rel="noopener noreferrer">GitHub</a>
        <a href={siteConfig.social.twitter.link} class="text-slate-600 hover:text-slate-900 dark:text-slate-300 dark:hover:text-white no-underline" target="_blank" rel="noopener noreferrer">X</a>
        <a href={siteConfig.social.linkedin.link} class="text-slate-600 hover:text-slate-900 dark:text-slate-300 dark:hover:text-white no-underline" target="_blank" rel="noopener noreferrer">LinkedIn</a>
      </div>
    </div>
  </div>
</footer>
